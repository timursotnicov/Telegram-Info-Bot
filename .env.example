# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI model (default: free Gemini Flash via OpenRouter)
AI_MODEL=google/gemini-2.0-flash-exp:free

# Environment: dev or prod
APP_ENV=dev

# Restrict bot usage to Telegram user IDs, comma-separated. Optional.
ALLOWED_USERS=

# Database path
DB_PATH=savebot.db

# Polling (true) or Webhook mode
USE_POLLING=true

# Webhook settings (only if USE_POLLING=false)
WEBHOOK_HOST=https://your-server.com
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8443
