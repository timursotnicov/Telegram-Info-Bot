# Production environment. Copy to .env.prod on the server and fill secrets.
APP_ENV=prod

# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI model
AI_MODEL=google/gemini-2.0-flash-001

# Restrict bot usage to Telegram user IDs, comma-separated. Optional.
ALLOWED_USERS=

# Production database path inside the Docker container.
DB_PATH=/data/savebot.db

# Production uses long polling. No public HTTP port is exposed.
USE_POLLING=true
